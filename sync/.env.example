# URL do projeto Supabase (Project Settings > API > Project URL)
SUPABASE_URL=https://xxxx.supabase.co

# Service role key do Supabase (Project Settings > API > service_role).
# Atenção: ignora RLS — é uma chave de servidor, nunca exponha no front-end.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ID da planilha (a parte entre /d/ e /edit na URL do Google Sheets)
GOOGLE_SHEETS_ID=1U7-LGnPc9JktExevHyZMTEY8kPcwzI3yf_1hjsRpaTM

# Caminho do arquivo JSON da service account do Google Cloud (uso local).
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Alternativa para deploy (Railway): o JSON da service account em base64.
# Se definido, tem prioridade sobre GOOGLE_SERVICE_ACCOUNT_FILE.
# GOOGLE_SERVICE_ACCOUNT_BASE64=
