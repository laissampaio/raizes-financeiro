# URL do projeto Supabase (Dashboard → Settings → API → Project URL)
VITE_SUPABASE_URL=

# Chave pública (anon) do Supabase (Dashboard → Settings → API → Project API keys → anon public)
# É seguro expor no frontend — os dados são protegidos pelos GRANTs do banco.
VITE_SUPABASE_ANON_KEY=

# Fine-Grained PAT do GitHub com permissão Actions → Read & Write neste repositório.
# Usado pelo botão Atualizar para disparar o workflow de sync.
# Risco: quem ler o bundle JS pode acionar syncs extras (gasta minutos do Actions).
VITE_GITHUB_TOKEN=
