# Client ID OAuth do Google Cloud Console (tipo "Aplicativo da Web")
VITE_GOOGLE_CLIENT_ID=

# Chave da API da Anthropic (sk-ant-...)
# Atencao: chamada a Claude API e feita direto do browser (sem backend),
# entao essa chave fica embutida no bundle JS publicado.
# Configure um limite de gasto na console da Anthropic antes de publicar.
VITE_ANTHROPIC_API_KEY=

# ID da planilha Google Sheets (a parte entre /d/ e /edit na URL)
VITE_GOOGLE_SHEETS_ID=
